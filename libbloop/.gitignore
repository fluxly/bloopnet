# ── Rust ──────────────────────────────────────────────────────────────────────

# Build artifacts (workspace and any standalone crates)
target/

# ── wasm-pack ─────────────────────────────────────────────────────────────────

# Default wasm-pack output directory
pkg/

# Custom wasm-pack output used by examples/web-terminal
# (wasm-pack also drops a * .gitignore here, but be explicit)
examples/web-terminal/wasm/

# If bloop-js ever gets its own built wasm drop
js/bloop-js/wasm/

# ── JavaScript / TypeScript ───────────────────────────────────────────────────

node_modules/

# Vite / tsc build output
dist/
examples/web-terminal/dist/
js/bloop-js/dist/

# ── Environment and secrets ───────────────────────────────────────────────────

.env
.env.*
!.env.example

# Private keys, certificates, credentials
*.pem
*.key
*.p12
*.pfx
*.crt
credentials.json
secrets.json

# ── OS ────────────────────────────────────────────────────────────────────────

.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
desktop.ini

# ── Editors and IDEs ──────────────────────────────────────────────────────────

.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace

# ── Test and debug artifacts ──────────────────────────────────────────────────

# Playwright
test-results/
playwright-report/
/tmp/bloop_*.png

